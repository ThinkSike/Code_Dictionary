   ],
   "source": [
    "def jump(nums):\n",
    "    jumps = 0\n",
    "    current_end = 0\n",
    "    farthest = 0\n",
    "    \n",
    "    for i in range(len(nums) - 1):\n",
    "        farthest = max(farthest, i + nums[i])\n",
    "        \n",
    "        if i == current_end:\n",
    "            jumps += 1\n",
    "            current_end = farthest\n",
    "            \n",
    "    return jumps"
   ]
  }
 ],
