# Max Consecutive Ones
class Solution:
    def findMaxConsecutiveOnes(self, nums: List[int]) -> int:
        i = 0
        consecutive = 0 
        max_consecutive = 0 
        for i in range(len(nums)):
            if nums[i] == 1:
                consecutive += 1
                max_consecutive = max(max_consecutive, consecutive)
            else:
                consecutive = 0
                i = i + 1
        return max_consecutive


