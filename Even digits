# Even number of digits in a number

count = sum(1 for num in nums if len(str(num)) % 2 == 0)
print(count)

class Solution:
    def findNumbers(self, nums: List[int]) -> int:
        count = 0
        for num in nums:
            digitCount = 0
            digits = num
            if digits == 0:
                digitCount = 1
            while digits > 0:
                digits //= 10
                digitCount += 1
            if digitCount % 2 == 0:
                count += 1
        return count 
